{
  "name": "@runcanon/core",
  "version": "0.1.1",
  "description": "Episode segmentation, sequence-aware clustering, skill generation, and scoring",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.750.0",
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@google/genai": "^1.5.0",
    "@runcanon/spec": "workspace:*",
    "fast-levenshtein": "^3.0.0",
    "js-yaml": "^4.2.0",
    "natural": "^8.0.1",
    "tar": "^7.4.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@runcanon/eslint-config": "workspace:*",
    "@runcanon/prettier-config": "workspace:*",
    "@runcanon/tsconfig": "workspace:*",
    "@runcanon/vitest-config": "workspace:*",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
