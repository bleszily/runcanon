{
  "name": "@runcanon/mcp",
  "version": "0.1.1",
  "description": "MCP server for skill management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:tools": "node scripts/test-mcp-tools.mjs",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@runcanon/core": "workspace:*",
    "@runcanon/spec": "workspace:*",
    "@runcanon/telemetry": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.24.1"
  },
  "bin": {
    "runcanon-mcp": "./dist/bin.cjs"
  },
  "devDependencies": {
    "@runcanon/eslint-config": "workspace:*",
    "@runcanon/prettier-config": "workspace:*",
    "@runcanon/tsconfig": "workspace:*",
    "@runcanon/vitest-config": "workspace:*",
    "@types/node": "^22.13.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
