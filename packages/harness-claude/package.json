{
  "name": "@runcanon/harness-claude",
  "version": "0.1.1",
  "description": "Claude Code harness integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@runcanon/spec": "workspace:*"
  },
  "devDependencies": {
    "@runcanon/eslint-config": "workspace:*",
    "@runcanon/prettier-config": "workspace:*",
    "@runcanon/tsconfig": "workspace:*",
    "@runcanon/vitest-config": "workspace:*",
    "@types/node": "^22.13.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
