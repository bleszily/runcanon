{
  "name": "@runcanon/cli",
  "version": "0.1.1",
  "description": "Command-line interface for RunCanon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "runcanon": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@runcanon/core": "workspace:*",
    "@runcanon/spec": "workspace:*",
    "commander": "^13.1.0",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@runcanon/eslint-config": "workspace:*",
    "@runcanon/prettier-config": "workspace:*",
    "@runcanon/tsconfig": "workspace:*",
    "@runcanon/vitest-config": "workspace:*",
    "@types/node": "^22.13.0",
    "esbuild": "^0.28.1",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "zod": "^3.24.1"
  }
}
